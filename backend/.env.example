# Port the server listens on. Fly injects this automatically in production.
PORT=3001

# Origin allowed by CORS. In production, your Vercel URL.
FRONTEND_ORIGIN=http://localhost:3000

# SQLite file path. On Fly this points at the mounted volume (/data/sales.db).
DATABASE_PATH=sales.db

# Optional. When absent, the AI agent degrades gracefully and no Claude
# calls are made. Deliberately NOT set in production until the rate limiting
# and budget guardrails land.
ANTHROPIC_API_KEY=
